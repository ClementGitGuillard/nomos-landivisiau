---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import data from '../data/home.json';

const { marques, selection, title, description } = {
  marques: data.marques,
  selection: data.selection,
  title: data.seo.title,
  description: data.seo.description,
};
---

<Layout title={title} description={description}>
  <Header />

  <!-- ============ HERO ============ -->
  <section class="relative w-full overflow-hidden">
    <img
      src={`/${data.hero.image}`}
      alt={data.hero.imageAlt}
      width="1920" height="1280"
      loading="eager" fetchpriority="high"
      class="block aspect-[4/5] max-h-[90svh] w-full object-cover object-[28%_center] sm:aspect-[16/9] lg:aspect-[2/1]"
    />
    <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-noir/85 via-noir/15 to-noir/40"></div>

    <div class="absolute inset-x-0 bottom-0 flex items-end justify-between gap-6 px-6 pb-8 sm:px-10 sm:pb-12">
      <!-- Lockup logo -->
      <div class="flex items-center gap-4 sm:gap-5">
        <img src="/logo.png" alt="Monogramme NOMOS Kéruzec-Méar" width="120" height="120" class="h-16 w-16 object-contain sm:h-24 sm:w-24" loading="eager" />
        <div class="font-logo leading-none text-creme">
          <span class="block text-3xl tracking-[0.18em] sm:text-5xl">NOMOS</span>
          <span class="mt-1 block text-center text-[0.55rem] tracking-eyebrow text-creme/70 sm:text-xs">par</span>
          <span class="block text-center text-[0.7rem] tracking-[0.28em] text-creme/90 sm:text-base">KERUZEC-MEAR</span>
        </div>
      </div>

      <!-- Adresse -->
      <div class="text-right text-[0.6rem] uppercase leading-relaxed tracking-wide2 text-creme/80 sm:text-xs">
        <p>{data.hero.addressLine1}</p>
        <p>{data.hero.addressLine2}</p>
        <p class="mt-3">{data.hero.hoursLine1}</p>
      </div>
    </div>
  </section>

  <!-- ============ MARQUES (bandeau blanc) ============ -->
  <section class="bg-blanc py-8" aria-label="Maisons distribuées">
    <div class="mx-auto flex max-w-7xl flex-wrap items-center justify-center gap-x-10 gap-y-6 px-6 sm:gap-x-14">
      {marques.map((m) => (
        <img src={`/marques/${m.file}`} alt={`${m.name} — distribué chez Nomos`} class="h-6 w-auto object-contain opacity-80 sm:h-7" loading="lazy" />
      ))}
    </div>
  </section>

  <!-- ============ MANIFESTE ============ -->
  <section id="manifeste" class="bg-noir py-24 sm:py-32">
    <div class="mx-auto max-w-3xl px-6 text-center">
      <span class="text-eyebrow uppercase tracking-eyebrow text-gris-clair">— Manifeste —</span>
      <h1 class="mt-8 font-body text-h2 font-light leading-snug text-creme">
        {data.manifeste.title}<br /><span class="text-gris">{data.manifeste.highlight}</span>
      </h1>
      <p class="mx-auto mt-10 max-w-prose text-base leading-relaxed text-gris">
        {data.manifeste.description}
      </p>
    </div>
  </section>

  <!-- ============ SÉLECTION ============ -->
  <section id="selection" class="relative overflow-hidden bg-noir-2 py-24 sm:py-28">
    <img src="/texture-selection-nomos.webp" alt="" aria-hidden="true" class="absolute inset-0 h-full w-full object-cover opacity-[0.55]" loading="lazy" />
    <div class="absolute inset-0 bg-gradient-to-b from-noir/40 via-noir/25 to-noir/45"></div>
    <div class="relative mx-auto max-w-7xl px-6">
      <div class="flex flex-col justify-between gap-6 md:flex-row md:items-end">
        <div>
          <span class="text-eyebrow uppercase tracking-eyebrow text-gris-clair">— Sélection —</span>
          <h2 class="mt-5 font-body text-h2 font-light leading-tight text-creme">
            {data.selectionTitle}
          </h2>
        </div>
        <p class="max-w-xs text-eyebrow uppercase leading-relaxed tracking-wide2 text-gris md:text-right">
          {data.selectionSubtitle}
        </p>
      </div>

      <div class="relative mt-12">
        <div id="sel-track" class="no-scrollbar flex snap-x snap-mandatory gap-4 overflow-x-auto scroll-smooth pb-4">
          {selection.map((s) => (
            <article class="group relative aspect-[3/4] w-[68%] flex-none snap-start overflow-hidden sm:w-[42%] lg:w-[23%]">
              <img src={`/${s.img}`} alt={`${s.label} — sélection Nomos Landivisiau`} class="h-full w-full object-cover grayscale transition-all duration-700 group-hover:scale-105 group-hover:grayscale-0" loading="lazy" />
              <div class="absolute inset-0 bg-gradient-to-t from-noir/80 via-transparent to-transparent"></div>
              <span class="absolute bottom-4 left-4 text-eyebrow uppercase tracking-eyebrow text-creme">{s.label}</span>
            </article>
          ))}
        </div>
        <div class="mt-6 flex justify-end gap-3">
          <button id="sel-prev" aria-label="Précédent" class="flex h-10 w-10 items-center justify-center border border-white/20 text-creme/70 transition-colors hover:border-creme hover:text-creme">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3"><path d="M15 6l-6 6 6 6"/></svg>
          </button>
          <button id="sel-next" aria-label="Suivant" class="flex h-10 w-10 items-center justify-center border border-white/20 text-creme/70 transition-colors hover:border-creme hover:text-creme">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3"><path d="M9 6l6 6-6 6"/></svg>
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ LE LIEU ============ -->
  <section id="le-lieu" class="bg-noir py-24 sm:py-28">
    <div class="mx-auto grid max-w-7xl items-center gap-12 px-6 lg:grid-cols-2 lg:gap-20">
      <div>
        <span class="text-eyebrow uppercase tracking-eyebrow text-gris-clair">— Le Lieu —</span>
        <h2 class="mt-5 font-body text-h2 font-light leading-tight text-creme">
          {data.lieu.title}
        </h2>
        <div class="mt-8 space-y-5 text-base leading-relaxed text-gris">
          {data.lieu.paragraphs.map((p: string, i: number) => (
            <p class={i === data.lieu.paragraphs.length - 1 ? "text-creme" : ""}>
              {p}
            </p>
          ))}
        </div>
      </div>
      <div class="aspect-[4/5] overflow-hidden ring-inset ring-[3px] ring-[#a4a2a2]/25">
        <img src={`/${data.lieu.image}`} alt={data.lieu.imageAlt} width="1200" height="1500" class="h-full w-full object-cover" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- ============ EN CE MOMENT ============ -->
  <section class="bg-[#B5B5B5] py-24 sm:py-28">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mx-auto max-w-2xl text-center">
        <span class="text-eyebrow uppercase tracking-eyebrow text-noir/55">— En ce moment —</span>
        <h2 class="mt-5 font-body text-h2 font-light leading-tight text-noir">{data.enCeMoment.title}</h2>
        <p class="mt-6 text-base leading-relaxed text-[#3b3a3a]">
          {data.enCeMoment.description.split('\n').map((line: string) => (
            <>
              {line}<br />
            </>
          ))}
        </p>
      </div>

      <!-- Rangée haute : gauche · centre (2 empilées) · droite -->
      <div class="mt-14 grid gap-4 sm:grid-cols-3 sm:h-[280px]">
        <div class="h-44 overflow-hidden sm:h-auto">
          <img src={`/${data.enCeMoment.images[0].src}`} alt={data.enCeMoment.images[0].alt} class="h-full w-full object-cover" loading="lazy" />
        </div>
        <div class="grid grid-rows-2 gap-4">
          <div class="h-28 overflow-hidden sm:h-auto">
            <img src={`/${data.enCeMoment.images[1].src}`} alt={data.enCeMoment.images[1].alt} class="h-full w-full object-cover" loading="lazy" />
          </div>
          <div class="h-28 overflow-hidden sm:h-auto">
            <img src={`/${data.enCeMoment.images[2].src}`} alt={data.enCeMoment.images[2].alt} class="h-full w-full object-cover" loading="lazy" />
          </div>
        </div>
        <div class="h-44 overflow-hidden sm:h-auto">
          <img src={`/${data.enCeMoment.images[3].src}`} alt={data.enCeMoment.images[3].alt} class="h-full w-full object-cover" loading="lazy" />
        </div>
      </div>

      <!-- Rangée basse : 2 grandes images -->
      <div class="mt-4 grid gap-4 sm:grid-cols-2 sm:h-[390px]">
        <div class="h-64 overflow-hidden sm:h-auto">
          <img src={`/${data.enCeMoment.images[4].src}`} alt={data.enCeMoment.images[4].alt} class="h-full w-full object-cover object-center" loading="lazy" />
        </div>
        <div class="h-64 overflow-hidden sm:h-auto">
          <img src={`/${data.enCeMoment.images[5].src}`} alt={data.enCeMoment.images[5].alt} class="h-full w-full object-cover" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- ============ L'HISTOIRE ============ -->
  <section id="histoire" class="bg-noir py-24 sm:py-28">
    <div class="mx-auto grid max-w-7xl items-center gap-12 px-6 lg:grid-cols-2 lg:gap-20">
      <div class="aspect-[4/3] overflow-hidden ring-inset ring-[3px] ring-[#a4a2a2]/25">
        <img src={`/${data.histoire.image}`} alt={data.histoire.imageAlt} width="1200" height="900" class="h-full w-full object-cover" loading="lazy" />
      </div>
      <div>
        <span class="text-eyebrow uppercase tracking-eyebrow text-gris-clair">— L'Histoire —</span>
        <h2 class="mt-5 font-body text-h2 font-light leading-tight text-creme">{data.histoire.title}</h2>
        <div class="mt-8 space-y-5 text-base leading-relaxed text-gris">
          {data.histoire.paragraphs.map((p: string, i: number) => (
            <p class={i === data.histoire.paragraphs.length - 1 ? "text-creme" : ""}>
              {p}
            </p>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ============ OBJET | MATIÈRE | ÉMOTION ============ -->
  <section class="relative overflow-hidden py-20 text-center">
    <img src="/texture-objet-matiere-emotion-nomos.webp" alt="" aria-hidden="true" class="absolute inset-0 h-full w-full object-cover opacity-50" loading="lazy" />
    <div class="absolute inset-0 bg-noir/40"></div>
    <div class="relative mx-auto max-w-4xl px-6">
      <h2 class="font-body text-h2 font-light tracking-[0.3em] text-creme">OBJET <span class="text-gris">|</span> MATIÈRE <span class="text-gris">|</span> ÉMOTION</h2>
      <p class="mt-6 text-eyebrow uppercase tracking-eyebrow text-gris-clair">Même regard · Même exigence · Même ADN</p>
    </div>
  </section>

  <!-- ============ FONDATEUR ============ -->
  <section class="bg-noir-2 py-24 sm:py-28">
    <div class="mx-auto grid max-w-7xl gap-12 px-6 lg:grid-cols-2 lg:gap-16">
      <div>
        <span class="text-eyebrow uppercase tracking-eyebrow text-gris-clair">— Fondateur —</span>
        <h2 class="mt-5 font-body text-[2.5rem] font-light leading-none text-creme">{data.fondateur.name}</h2>
        <p class="mt-3 text-eyebrow uppercase tracking-eyebrow text-gris">{data.fondateur.title}</p>
        <div class="mt-8 space-y-5 text-[0.95rem] leading-relaxed text-gris">
          {data.fondateur.paragraphs.map((p: string) => (
            <p>{p}</p>
          ))}
        </div>
        <blockquote class="mt-10 border-l border-gris-clair/40 pl-6 font-body text-lg font-light italic leading-relaxed text-creme">
          {data.fondateur.quote.split('\n').map((line: string, i: number, arr: string[]) => (
            <>
              {i === 0 && '« '}{line}{i === arr.length - 1 ? ' »' : <br />}
            </>
          ))}
        </blockquote>
      </div>
      <div class="relative aspect-[4/5] overflow-hidden ring-inset ring-[3px] ring-[#a4a2a2]/25 lg:aspect-auto">
        <img src={`/${data.fondateur.image}`} alt={data.fondateur.imageAlt} width="1000" height="1250" class="absolute inset-0 h-full w-full object-cover object-top" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- ============ PARTENARIATS ============ -->
  <section id="partenariats" class="bg-[#B5B5B5] py-24 sm:py-28">
    <div class="mx-auto grid max-w-7xl gap-12 px-6 lg:grid-cols-[0.82fr_1fr] lg:items-center lg:gap-20">
      <div class="aspect-square overflow-hidden ring-inset ring-[3px] ring-[#a4a2a2]/25">
        <img src={`/${data.partenariats.image}`} alt={data.partenariats.imageAlt} width="581" height="830" class="h-full w-full object-cover object-center" loading="lazy" />
      </div>
      <div>
        <span class="text-eyebrow uppercase tracking-eyebrow text-noir/55">— Partenariats —</span>
        <h2 class="mt-5 font-body text-h2 font-light leading-tight text-noir">{data.partenariats.title}</h2>
        <p class="mt-4 text-eyebrow uppercase tracking-wide2 text-noir/60">{data.partenariats.subtitle}</p>
        <div class="mt-8 space-y-5 text-base leading-relaxed text-noir/75">
          {data.partenariats.paragraphs.map((p: string) => (
            <p>{p}</p>
          ))}
        </div>
        <a href="tel:+33298693490" class="mt-8 inline-flex items-center gap-3 border border-noir/40 px-7 py-4 text-eyebrow uppercase tracking-eyebrow text-noir transition-colors hover:bg-noir hover:text-creme">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          02 98 69 34 90
        </a>
      </div>
    </div>
  </section>

  <!-- ============ COORDONNÉES + CARTE ============ -->
  <section class="bg-noir-2 py-20">
    <div class="mx-auto grid max-w-4xl items-stretch gap-8 px-6 md:grid-cols-2">
      <div class="flex h-full flex-col border border-white/15">
        <div class="flex flex-1 items-center gap-4 border-b border-white/15 p-8">
          <img src="/logo.png" alt="Monogramme NOMOS Kéruzec-Méar" width="64" height="64" class="h-14 w-14 object-contain" loading="lazy" />
          <div class="font-logo text-creme">
            <span class="block text-2xl leading-none tracking-[0.18em]">NOMOS</span>
            <span class="mt-2 block text-center text-[0.55rem] leading-none tracking-eyebrow text-creme/70">par</span>
            <span class="mt-1.5 block text-center text-[0.72rem] leading-none tracking-[0.26em] text-creme/90">KERUZEC-MEAR</span>
          </div>
        </div>
        <div class="flex flex-1 items-center border-b border-white/15 p-8 text-sm leading-relaxed text-gris">
          <div>
            {data.contact.address.split(',').map((part: string) => (
              <p>{part.trim()}</p>
            ))}
          </div>
        </div>
        <div class="flex flex-1 items-center border-b border-white/15 p-8 text-sm leading-relaxed text-gris">
          <div>
            {data.contact.hours.split('\n').map((line: string) => (
              <p class={line.includes('Mardi') ? "text-creme" : ""}>{line}</p>
            ))}
            <p class="text-gris/70">{data.contact.hoursClosed}</p>
          </div>
        </div>
        <a href={`tel:+33298693490`} class="flex flex-1 items-center gap-3 p-8 text-sm tracking-wide2 text-creme transition-colors hover:text-gris-clair">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          {data.contact.phone}
        </a>
      </div>
      <div class="overflow-hidden">
        <img src={`/${data.contact.map}`} alt="Plan de situation de Nomos à Landivisiau" width="900" height="1273" class="block w-full" loading="lazy" />
      </div>
    </div>
  </section>

  <script is:inline>
    (function () {
      const track = document.getElementById('sel-track');
      if (!track) return;
      const step = () => Math.min(track.clientWidth * 0.8, 600);
      document.getElementById('sel-next')?.addEventListener('click', () => track.scrollBy({ left: step(), behavior: 'smooth' }));
      document.getElementById('sel-prev')?.addEventListener('click', () => track.scrollBy({ left: -step(), behavior: 'smooth' }));
    })();
  </script>
</Layout>
