---
export interface Props { simple?: boolean }
const { simple = false } = Astro.props;

const nav = [
  { label: 'Manifeste', href: '/#manifeste' },
  { label: 'Sélection', href: '/#selection' },
  { label: 'Le Lieu', href: '/#le-lieu' },
  { label: "L'Histoire", href: '/#histoire' },
];
---

<header id="site-header" class="fixed inset-x-0 top-0 z-50 transition-colors duration-500">
  <div class="mx-auto flex max-w-7xl items-center justify-between gap-6 px-6 py-4">
    <!-- Marque -->
    <a href="/" class="flex items-center gap-3" aria-label="NOMOS — accueil">
      <img src="/logo.png" alt="Monogramme NOMOS Kéruzec-Méar" width="40" height="40" class="h-9 w-9 object-contain" />
      <span class="font-logo text-xl tracking-[0.2em] text-creme">NOMOS</span>
    </a>

    {!simple && (
      <>
        <!-- Nav desktop -->
        <nav class="hidden items-center gap-9 lg:flex" aria-label="Navigation principale">
          {nav.map((n) => (
            <a href={n.href} class="text-eyebrow uppercase tracking-eyebrow text-creme/80 transition-colors hover:text-creme">{n.label}</a>
          ))}
        </nav>

        <!-- Burger mobile -->
        <button id="burger" class="lg:hidden text-creme" aria-label="Ouvrir le menu" aria-expanded="false">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><line x1="3" y1="7" x2="21" y2="7"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="17" x2="21" y2="17"/></svg>
        </button>
      </>
    )}
  </div>

  {!simple && (
    <!-- Menu mobile -->
    <div id="mobile-menu" class="hidden bg-noir/98 backdrop-blur border-t border-white/10 lg:hidden">
      <nav class="flex flex-col px-6 py-4" aria-label="Navigation mobile">
        {nav.map((n) => (
          <a href={n.href} class="border-b border-white/5 py-3 text-eyebrow uppercase tracking-eyebrow text-creme/85">{n.label}</a>
        ))}
        <a href="tel:+33298693490" class="py-4 text-sm tracking-wide2 text-creme">02 98 69 34 90</a>
      </nav>
    </div>
  )}
</header>

<script is:inline>
  (function () {
    const header = document.getElementById('site-header');
    const onScroll = () => {
      if (window.scrollY > 40) header.classList.add('header-solid');
      else header.classList.remove('header-solid');
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });

    const burger = document.getElementById('burger');
    const menu = document.getElementById('mobile-menu');
    if (burger && menu) {
      burger.addEventListener('click', () => {
        const open = menu.classList.toggle('hidden');
        burger.setAttribute('aria-expanded', String(!open));
      });
      menu.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => menu.classList.add('hidden')));
    }
  })();
</script>

<style>
  #site-header.header-solid { background-color: rgba(10, 10, 10, 0.92); backdrop-filter: blur(8px); }
</style>
